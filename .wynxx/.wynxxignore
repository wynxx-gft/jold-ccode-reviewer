# -----------------------------------------------------------------------------
# Wynxx Auto-Ingestion Ignore File (.wynxxignore)
# Files / folders listed here WILL NOT be sent for vectorization.
# Focus on keeping only useful text content (source code, markdown, txt, etc.).
# -----------------------------------------------------------------------------

# Version control / metadata
.git/
.svn/
.hg/
.idea/
.vscode/
.DS_Store
Thumbs.db

# Build outputs / dependencies
dist/
build/
out/
coverage/
node_modules/
target/
bin/
obj/
.next/
.turbo/
.parcel-cache/
.yarn/
.pnpm-store/
.gradle/
__pycache__/
*.pyc
*.pyo
*.pyd

# Environment / credential files (do not vectorize)
.env
.env.*
*.pem
*.key
*.cer
*.crt
*.pfx

# Temporary Logs
*.log
*.tmp
*.temp
*.swp
*.swo
*.bak
*.orig

# Image binary files
*.png
*.jpg
*.jpeg
*.gif
*.svg
*.ico
*.webp
*.avif
*.bmp
*.tif
*.tiff
*.psd

# Document binary files (non-plain text)
*.pdf
*.doc
*.docx
*.xls
*.xlsx
*.ppt
*.pptx
*.odt
*.ods
*.odp

# Audio / video files
*.mp3
*.wav
*.flac
*.ogg
*.m4a
*.aac
*.wma
*.mp4
*.mkv
*.avi
*.mov
*.wmv
*.webm

# Font files
*.ttf
*.otf
*.woff
*.woff2

# Zipped / compact files
*.zip
*.tar
*.gz
*.tgz
*.bz2
*.7z
*.rar
*.xz

# Executables / compiled libraries
*.exe
*.dll
*.so
*.dylib
*.bin
*.dat
*.class
*.jar
*.war
*.ear
*.apk
*.ipa

# Other large binaries
*.iso
*.img
*.lock
package-lock.json
yarn.lock
pnpm-lock.yaml

# Itens who normally not add semantic context
*.min.js
*.min.css
*.map

# Placeholders 
.gitkeep

# -----------------------------------------------------------------------------
# Include additional patterns below as needed.
# -----------------------------------------------------------------------------
