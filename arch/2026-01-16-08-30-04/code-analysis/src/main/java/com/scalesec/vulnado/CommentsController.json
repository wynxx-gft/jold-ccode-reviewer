      {
        "name": "Get All Comments",
        "steps": [
          "Client sends GET request to /comments with x-auth-token header",
          "CommentsController.comments() receives the request",
          "User.assertAuth() validates the token against the secret",
          "Comment.fetch_all() retrieves all comments",
          "Controller returns the comment list as JSON response"
        ],
        "exceptions": [
          "If token validation fails, authentication error is returned"
        ]
      },
      {
        "name": "Create Comment",
        "steps": [
          "Client sends POST request to /comments with comment data and x-auth-token header",
          "CommentsController.createComment() receives the request",
          "Comment.create() creates a new comment with username and body",
          "Controller returns the created comment as JSON response"
        ],
        "exceptions": []
      },
      {
        "name": "Delete Comment",
        "steps": [
          "Client sends DELETE request to /comments/{id} with x-auth-token header",
          "CommentsController.deleteComment() receives the request",
          "Comment.delete() removes the comment with the specified ID",
          "Controller returns boolean result as JSON response"
        ],
        "exceptions": []
      }
    ]
