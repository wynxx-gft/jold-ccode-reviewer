    {
      "name": "Authentication Flow",
      "description": "User authentication process through the login endpoint",
      "participants": [
        {
          "name": "Client",
          "type": "actor",
          "category": "external"
        },
        {
          "name": "LoginController",
          "type": "class",
          "category": "controller"
        },
        {
          "name": "User",
          "type": "class",
          "category": "model"
        },
        {
          "name": "Postgres",
          "type": "class",
          "category": "database"
        }
      ],
      "interactions": [
        {
          "order": 1,
          "from": "Client",
          "to": "LoginController",
          "message": "POST /login with username and password",
          "type": "synchronous",
          "condition": "",
          "notes": "Client initiates login request",
          "parameters": [
            {
              "name": "LoginRequest",
              "type": "JSON",
              "value": "{username: string, password: string}"
            }
          ],
          "returnValue": {
            "type": "void",
            "description": ""
          }
        },
        {
          "order": 2,
          "from": "LoginController",
          "to": "User",
          "message": "fetch(username)",
          "type": "synchronous",
          "condition": "",
          "notes": "Retrieve user by username",
          "parameters": [
            {
              "name": "username",
              "type": "String",
              "value": "username from request"
            }
          ],
          "returnValue": {
            "type": "User",
            "description": "User object if found"
          }
        },
        {
          "order": 3,
          "from": "LoginController",
          "to": "Postgres",
          "message": "md5(password)",
          "type": "synchronous",
          "condition": "",
          "notes": "Hash the provided password",
          "parameters": [
            {
              "name": "password",
              "type": "String",
              "value": "password from request"
            }
          ],
          "returnValue": {
            "type": "String",
            "description": "MD5 hash of password"
          }
        },
        {
          "order": 4,
          "from": "LoginController",
          "to": "LoginController",
          "message": "Compare hashed password with stored hash",
          "type": "synchronous",
          "condition": "",
          "notes": "Verify if passwords match",
          "parameters": [],
          "returnValue": {
            "type": "boolean",
            "description": "True if passwords match"
          }
        },
        {
          "order": 5,
          "from": "LoginController",
          "to": "User",
          "message": "token(secret)",
          "type": "synchronous",
          "condition": "Passwords match",
          "notes": "Generate authentication token",
          "parameters": [
            {
              "name": "secret",
              "type": "String",
              "value": "Application secret key"
            }
          ],
          "returnValue": {
            "type": "String",
            "description": "JWT token"
          }
        },
        {
          "order": 6,
          "from": "LoginController",
          "to": "Client",
          "message": "Return LoginResponse with token",
          "type": "return",
          "condition": "Authentication successful",
          "notes": "Send authentication token to client",
          "parameters": [],
          "returnValue": {
            "type": "LoginResponse",
            "description": "Response containing authentication token"
          }
        }
      ],
      "alternativeFlows": [
        {
          "condition": "Password hash doesn't match",
          "interactions": [
            {
              "order": 1,
              "from": "LoginController",
              "to": "Client",
              "message": "Throw Unauthorized exception with 'Access Denied' message",
              "type": "return",
              "condition": "Passwords don't match",
              "notes": "Authentication failure",
              "parameters": [],
              "returnValue": {
                "type": "HTTP 401",
                "description": "Unauthorized response"
              }
            }
          ]
        },
        {
          "condition": "User not found",
          "interactions": [
            {
              "order": 1,
              "from": "LoginController",
              "to": "Client",
              "message": "NullPointerException when trying to access user.hashedPassword",
              "type": "return",
              "condition": "User not found",
              "notes": "Server error due to null user",
              "parameters": [],
              "returnValue": {
                "type": "HTTP 500",
                "description": "Server error response"
              }
            }
          ]
        }
