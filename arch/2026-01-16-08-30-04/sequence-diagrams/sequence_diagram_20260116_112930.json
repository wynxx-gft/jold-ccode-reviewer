  "notes": [
    {
      "attachedTo": "Postgres.md5",
      "content": "Using MD5 for password hashing is insecure and should be replaced with a more secure algorithm like bcrypt or Argon2",
      "type": "technical_detail"
    },
    {
      "attachedTo": "User.assertAuth",
      "content": "Token validation should include expiration checking and proper signature verification",
      "type": "constraint"
    },
    {
      "attachedTo": "LinkLister.getLinks",
      "content": "This method may be vulnerable to SSRF (Server-Side Request Forgery) attacks if it doesn't validate the URL properly",
      "type": "comment"
    },
    {
      "attachedTo": "CommentsController.createComment",
      "content": "No input validation is performed on comment body, potentially allowing XSS attacks",
      "type": "comment"
    }
  ],
